<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>sync-ad-maximo</display-name>

    <context-param>
        <param-name>config.location</param-name>
        <param-value>${SYNC_AD_MAXIMO_CONFIG}</param-value>
    </context-param>

    <filter>
        <filter-name>authFilter</filter-name>
        <filter-class>com.syncadmaximo.web.filter.AuthFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>authFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <servlet>
        <servlet-name>homeServlet</servlet-name>
        <servlet-class>com.syncadmaximo.web.servlet.HomeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>homeServlet</servlet-name>
        <url-pattern>/</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>loginServlet</servlet-name>
        <servlet-class>com.syncadmaximo.web.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>loginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>logoutServlet</servlet-name>
        <servlet-class>com.syncadmaximo.web.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>logoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>healthServlet</servlet-name>
        <servlet-class>com.syncadmaximo.web.servlet.HealthServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>healthServlet</servlet-name>
        <url-pattern>/health</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>demoServlet</servlet-name>
        <servlet-class>com.syncadmaximo.web.servlet.DemoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>demoServlet</servlet-name>
        <url-pattern>/demo</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>reportServlet</servlet-name>
        <servlet-class>com.syncadmaximo.web.servlet.ReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>reportServlet</servlet-name>
        <url-pattern>/report</url-pattern>
        <url-pattern>/report.csv</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>reportController</servlet-name>
        <servlet-class>com.syncadmaximo.web.servlet.ReportController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>reportController</servlet-name>
        <url-pattern>/api/reportes/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>mailPreviewServlet</servlet-name>
        <servlet-class>com.syncadmaximo.web.servlet.MailPreviewServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>mailPreviewServlet</servlet-name>
        <url-pattern>/mail/preview</url-pattern>
    </servlet-mapping>

    <session-config>
        <session-timeout>15</session-timeout>
    </session-config>
</web-app>
